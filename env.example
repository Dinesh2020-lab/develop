import { sendPaymentConfirmationEmail } from '../config/email.js'
import crypto from 'crypto'

// ── Start trial ─────────────────────────────────────────────────
export async function startTrial(req, res, next) {
  try {
    const user = req.user
    const status = user.getEditorStatus()

    if (status !== 'none') {
      return res.json({ status, editorAccess: user.editorAccess })
    }

    user.editorAccess.trialStarted = new Date()
    await user.save()

    res.json({
      message: 'Trial started! You have 24 hours of free access.',
      status: 'trial',
      editorAccess: user.editorAccess,
    })
  } catch (err) {
    next(err)
  }
}

// ── Get editor status ───────────────────────────────────────────
export async function getEditorStatus(req, res) {
  const status = req.user.getEditorStatus()
  const trialRemaining = !req.user.editorAccess.isPro && req.user.editorAccess.trialStarted
    ? Math.max(0, 24 * 60 * 60 * 1000 - (Date.now() - new Date(req.user.editorAccess.trialStarted).getTime()))
    : 0

  res.json({
    status,
    trialRemaining,
    editorAccess: req.user.editorAccess,
  })
}

// ── Verify Razorpay payment and activate Pro ────────────────────
export async function activatePro(req, res, next) {
  try {
    const { razorpay_payment_id, razorpay_order_id, razorpay_signature } = req.body

    if (!razorpay_payment_id) {
      return res.status(400).json({ error: 'Payment ID is required' })
    }

    // ── Verify signature (if order_id present) ──────────────────
    if (razorpay_order_id && razorpay_signature && process.env.RAZORPAY_KEY_SECRET) {
      const body    = razorpay_order_id + '|' + razorpay_payment_id
      const expected = crypto
        .createHmac('sha256', process.env.RAZORPAY_KEY_SECRET)
        .update(body)
        .digest('hex')

      if (expected !== razorpay_signature) {
        console.warn(`⚠️  Invalid payment signature for user ${req.user._id}`)
        return res.status(400).json({ error: 'Payment verification failed. Contact support.' })
      }
    }

    // ── Activate Pro ─────────────────────────────────────────────
    req.user.editorAccess.isPro     = true
    req.user.editorAccess.proSince  = new Date()
    req.user.editorAccess.paymentId = razorpay_payment_id
    await req.user.save()

    // Send confirmation email (don't await — don't block response)
    sendPaymentConfirmationEmail(req.user.email, req.user.username, razorpay_payment_id)
      .catch(err => console.error('Payment email failed:', err.message))

    console.log(`✅ Pro activated for ${req.user.email} (payment: ${razorpay_payment_id})`)

    res.json({
      message: 'Pro activated! Enjoy unlimited editor access.',
      status:  'pro',
      editorAccess: req.user.editorAccess,
    })
  } catch (err) {
    next(err)
  }
}
