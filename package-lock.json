import { useState } from 'react'
import Navbar from '../components/Navbar'
import { useAuth } from '../context/AuthContext'

const CATEGORIES = ['all', 'general', 'frontend', 'javascript', 'backend', 'python', 'react', 'help']
const CAT_COLORS = { general: '#888', frontend: 'var(--orange)', javascript: '#f7df1e', backend: 'var(--yellow)', python: '#4a9eff', react: '#61dafb', help: 'var(--accent)' }

function timeAgo(ts) {
  const d = Date.now() - ts
  if (d < 60000) return 'just now'
  if (d < 3600000) return `${Math.floor(d/60000)}m ago`
  if (d < 86400000) return `${Math.floor(d/3600000)}h ago`
  return `${Math.floor(d/86400000)}d ago`
}

export default function CommunityPage() {
  const { user, posts, addPost, addReply, likePost, deletePost } = useAuth()
  const [filter, setFilter] = useState('all')
  const [showNew, setShowNew] = useState(false)
  const [openPost, setOpenPost] = useState(null)
  const [newTitle, setNewTitle] = useState('')
  const [newBody, setNewBody] = useState('')
  const [newCat, setNewCat] = useState('general')
  const [replyText, setReplyText] = useState('')
  const [search, setSearch] = useState('')

  const initials = user?.username?.slice(0,2).toUpperCase() || '??'
  const avatarColor = user?.avatarColor || '#1D9E75'

  const filtered = posts.filter(p => {
    if (filter !== 'all' && p.category !== filter) return false
    if (search && !p.title.toLowerCase().includes(search.toLowerCase()) && !p.body.toLowerCase().includes(search.toLowerCase())) return false
    return true
  })

  function handlePost() {
    if (!newTitle.trim() || !newBody.trim()) return
    addPost({
      id: Date.now(), author: user.username, avatar: initials,
      color: avatarColor, title: newTitle.trim(), body: newBody.trim(),
      category: newCat, likes: 0, replies: [], createdAt: Date.now(),
    })
    setNewTitle(''); setNewBody(''); setNewCat('general'); setShowNew(false)
  }

  function handleReply(postId) {
    if (!replyText.trim()) return
    addReply(postId, {
      id: Date.now(), author: user.username, avatar: initials,
      color: avatarColor, body: replyText.trim(), likes: 0, createdAt: Date.now(),
    })
    setReplyText('')
  }

  const selectedPost = posts.find(p => p.id === openPost)

  return (
    <>
      <Navbar />
      <div className="community-wrap">
        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '1.5rem', flexWrap: 'wrap', gap: '.8rem' }}>
          <div>
            <h1 style={{ fontSize: '1.5rem', fontWeight: 700 }}>💬 Community</h1>
            <p style={{ color: 'var(--muted)', fontSize: '.88rem' }}>Ask questions, share knowledge, help others</p>
          </div>
          <button className="btn btn-primary" onClick={() => setShowNew(true)}>+ New Post</button>
        </div>

        {/* Search */}
        <input className="input" placeholder="🔍 Search posts..." value={search}
          onChange={e => setSearch(e.target.value)} style={{ marginBottom: '1rem' }} />

        {/* Category filter */}
        <div style={{ display: 'flex', gap: '.5rem', flexWrap: 'wrap', marginBottom: '1.5rem' }}>
          {CATEGORIES.map(c => (
            <button key={c} onClick={() => setFilter(c)}
              className="btn"
              style={{
                padding: '.3rem .8rem', fontSize: '.78rem',
                background: filter === c ? 'var(--accent)' : 'var(--bg3)',
                color: filter === c ? '#fff' : 'var(--muted)',
                border: `1px solid ${filter === c ? 'var(--accent)' : 'var(--border)'}`,
              }}>
              {c.charAt(0).toUpperCase() + c.slice(1)}
            </button>
          ))}
        </div>

        {/* New post form */}
        {showNew && (
          <div className="card" style={{ marginBottom: '1.5rem', border: '1px solid var(--accent)' }}>
            <h3 style={{ marginBottom: '1rem' }}>New Post</h3>
            <div className="form-group">
              <label>Title</label>
              <input className="input" placeholder="What's your question or topic?" value={newTitle} onChange={e => setNewTitle(e.target.value)} />
            </div>
            <div className="form-group">
              <label>Category</label>
              <select className="input" value={newCat} onChange={e => setNewCat(e.target.value)}>
                {CATEGORIES.filter(c => c !== 'all').map(c => <option key={c} value={c}>{c}</option>)}
              </select>
            </div>
            <div className="form-group">
              <label>Body</label>
              <textarea className="input" rows={4} placeholder="Describe your question or share your knowledge..." value={newBody} onChange={e => setNewBody(e.target.value)} />
            </div>
            <div style={{ display: 'flex', gap: '.8rem' }}>
              <button className="btn btn-primary" onClick={handlePost}>Post</button>
              <button className="btn btn-secondary" onClick={() => setShowNew(false)}>Cancel</button>
            </div>
          </div>
        )}

        {/* Post detail */}
        {selectedPost && (
          <div className="card" style={{ marginBottom: '1.5rem', border: '1px solid var(--purple)' }}>
            <button onClick={() => setOpenPost(null)} style={{ background: 'none', border: 'none', color: 'var(--muted)', cursor: 'pointer', marginBottom: '.8rem', fontSize: '.85rem' }}>← Back to posts</button>
            <div className="post-meta">
              <div className="post-avatar" style={{ background: selectedPost.color + '33', color: selectedPost.color }}>{selectedPost.avatar}</div>
              <strong>{selectedPost.author}</strong>
              <span className="post-category" style={{ color: CAT_COLORS[selectedPost.category] || 'var(--muted)' }}>{selectedPost.category}</span>
              <span style={{ color: 'var(--muted)', fontSize: '.78rem', marginLeft: 'auto' }}>{timeAgo(selectedPost.createdAt)}</span>
            </div>
            <h2 style={{ marginBottom: '.6rem', fontSize: '1.1rem' }}>{selectedPost.title}</h2>
            <p style={{ color: '#ccc', lineHeight: 1.7, marginBottom: '1rem' }}>{selectedPost.body}</p>
            <button onClick={() => likePost(selectedPost.id)} className="btn btn-secondary" style={{ fontSize: '.8rem', padding: '.3rem .8rem', marginBottom: '1.2rem' }}>
              ♥ {selectedPost.likes}
            </button>

            {/* Replies */}
            <div style={{ borderTop: '1px solid var(--border)', paddingTop: '1rem' }}>
              <h4 style={{ marginBottom: '.8rem', color: 'var(--muted)', fontSize: '.88rem' }}>
                {selectedPost.replies.length} {selectedPost.replies.length === 1 ? 'reply' : 'replies'}
              </h4>
              {selectedPost.replies.map(r => (
                <div key={r.id} className="reply-box" style={{ marginBottom: '.6rem' }}>
                  <div className="post-meta" style={{ marginBottom: '.4rem' }}>
                    <div className="post-avatar" style={{ background: r.color + '33', color: r.color, width: 24, height: 24, fontSize: '.65rem' }}>{r.avatar}</div>
                    <strong style={{ fontSize: '.85rem' }}>{r.author}</strong>
                    <span style={{ color: 'var(--muted)', fontSize: '.75rem', marginLeft: 'auto' }}>{timeAgo(r.createdAt)}</span>
                  </div>
                  <p style={{ color: '#ccc', fontSize: '.88rem', lineHeight: 1.6 }}>{r.body}</p>
                </div>
              ))}

              {/* Reply input */}
              <div style={{ display: 'flex', gap: '.6rem', marginTop: '1rem' }}>
                <textarea className="input" rows={2} placeholder="Write a reply..." value={replyText}
                  onChange={e => setReplyText(e.target.value)} style={{ flex: 1 }} />
                <button className="btn btn-primary" onClick={() => handleReply(selectedPost.id)}>Reply</button>
              </div>
            </div>
          </div>
        )}

        {/* Post list */}
        {!selectedPost && (
          <>
            {filtered.length === 0 && (
              <div style={{ textAlign: 'center', color: 'var(--muted)', padding: '3rem' }}>
                No posts found. Be the first to post! 🎉
              </div>
            )}
            {filtered.map(p => (
              <div key={p.id} className="post-card" onClick={() => setOpenPost(p.id)} style={{ cursor: 'pointer' }}>
                <div className="post-meta">
                  <div className="post-avatar" style={{ background: p.color + '33', color: p.color }}>{p.avatar}</div>
                  <strong style={{ fontSize: '.88rem' }}>{p.author}</strong>
                  <span className="post-category" style={{ color: CAT_COLORS[p.category] || 'var(--muted)' }}>{p.category}</span>
                  <span style={{ color: 'var(--muted)', fontSize: '.75rem', marginLeft: 'auto' }}>{timeAgo(p.createdAt)}</span>
                  {(user?.isAdmin || p.author === user?.username) && (
                    <button onClick={e => { e.stopPropagation(); deletePost(p.id) }}
                      style={{ background: 'none', border: 'none', color: '#f08080', cursor: 'pointer', fontSize: '.75rem' }}>✕</button>
                  )}
                </div>
                <h3 style={{ fontSize: '.95rem', fontWeight: 600, marginBottom: '.3rem' }}>{p.title}</h3>
                <p style={{ color: 'var(--muted)', fontSize: '.83rem', lineHeight: 1.5,
                  overflow: 'hidden', display: '-webkit-box', WebkitLineClamp: 2, WebkitBoxOrient: 'vertical' }}>
                  {p.body}
                </p>
                <div style={{ marginTop: '.6rem', display: 'flex', gap: '1rem', fontSize: '.78rem', color: 'var(--muted)' }}>
                  <span>♥ {p.likes}</span>
                  <span>💬 {p.replies.length} {p.replies.length === 1 ? 'reply' : 'replies'}</span>
                </div>
              </div>
            ))}
          </>
        )}
      </div>
    </>
  )
}
